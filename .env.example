# Copy to .env and fill in. Real environment variables override these.

# Required: GitHub personal access token (repo scope).
# Quick local value: GITHUB_TOKEN=$(gh auth token)
GITHUB_TOKEN=

# Required: target repository in owner/name form.
MERGEBOT_REPO=

# Optional overrides (defaults shown).
MERGEBOT_INTERVAL=30s
MERGEBOT_TIMEOUT=60m
MERGEBOT_MERGE_METHOD=squash
MERGEBOT_MIN_APPROVALS=2
MERGEBOT_RATE_LIMIT_WAIT=15m
MERGEBOT_RATE_LIMIT_RETRIES=3
MERGEBOT_ALLOW_UNSTABLE=false
MERGEBOT_ALLOW_UNRESOLVED=false
MERGEBOT_DRY_RUN=false

# Daemon mode (mergebot serve) only.
MERGEBOT_ADDR=127.0.0.1:8080
MERGEBOT_STATE=mergebot-queue.json
MERGEBOT_RECHECK_INTERVAL=5m
MERGEBOT_CONCURRENCY=1
# GitHub login for the My PRs dashboard (default: token owner).
MERGEBOT_REVIEW_AUTHOR=

# Delegate merging to the team merge queue (mergebot posts /queue and watches
# the bot's comment replies): set MERGEBOT_MERGE_MODE=merge-queue.
# Default: self — mergebot merges directly.
MERGEBOT_MERGE_MODE=self
